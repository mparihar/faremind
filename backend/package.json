{
  "name": "faremind-backend",
  "version": "0.2.0",
  "private": true,
  "description": "FareMind Backend API Gateway — Fastify microservice architecture",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npx prisma generate --schema ../prisma/schema.prisma && tsc",
    "start": "node --import tsx src/index.ts",
    "postinstall": "npx prisma generate --schema ../prisma/schema.prisma || true",
    "db:push": "prisma db push --schema ../prisma/schema.prisma",
    "db:studio": "prisma studio --schema ../prisma/schema.prisma",
    "db:generate": "prisma generate --schema ../prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/compress": "^8.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "ioredis": "^5.4.1",
    "openai": "^6.40.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "tsx": "^4.19.0",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.0.0",
    "typescript": "^5.6.0"
  }
}
