# ═══════════════════════════════════════
# FareMind Environment Variables
# Copy to .env and fill in real values
# ═══════════════════════════════════════

# ── Database ──────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/faremind

# ── Duffel (NDC Layer) ───────────────
DUFFEL_API_TOKEN=duffel_test_your_token_here
DUFFEL_API_URL=https://api.duffel.com

# ── Amadeus (GDS Layer) ──────────────
# AMADEUS_CLIENT_ID=your_client_id_here
# AMADEUS_CLIENT_SECRET=your_client_secret_here
# AMADEUS_API_URL=https://test.api.amadeus.com

# ── Mystifly ─────────────────────────
MYSTIFLY_USERNAME=your_username
MYSTIFLY_PASSWORD=your_password
MYSTIFLY_ACCOUNT_NUMBER=your_account_number
MYSTIFLY_SESSION_ID=your_session_id
MYSTIFLY_API_URL=https://restapidemo.myfarebox.com

# ── Stripe (Payments) ────────────────
STRIPE_SECRET_KEY=sk_test_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ── Brevo (Transactional Email) ──────
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=support@yourdomain.com

# ── AI / LLM ─────────────────────────
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
NEXT_PUBLIC_AI_CHATBOT_POOL_SIZE=30

# ── App URLs ─────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Server-side backend URL ──────────
# Used by Next.js API routes to proxy to backend (server-to-server)
# On Railway, set to internal private network URL for faster calls
BACKEND_URL=http://localhost:3001

# ── Backend-only vars ────────────────
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
ADMIN_JWT_SECRET=your_jwt_secret_here

# ── Notification Service ─────────────
NOTIFICATION_SERVICE_URL=http://localhost:8001

# ── Redis (optional) ─────────────────
# REDIS_URL=redis://localhost:6379
