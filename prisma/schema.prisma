model BookingRefund {
  id                 String       @id @default(cuid())
  bookingId          String       @map("booking_id")
  cancellationId     String?      @map("cancellation_id")
  changeRequestId    String?      @map("change_request_id")
  amount             Decimal      @db.Decimal(10, 2)
  currency           String       @default("USD")
  method             RefundMethod @default(ORIGINAL_PAYMENT)
  status             RefundStatus @default(INITIATED)
  providerRefundId   String?      @map("provider_refund_id")
  providerResponse   Json?        @map("provider_response")
  stripeRefundId     String?      @map("stripe_refund_id")
  processingDays     Int?         @map("processing_days")
  initiatedAt        DateTime     @default(now()) @map("initiated_at")
  completedAt        DateTime?    @map("completed_at")
  failedAt           DateTime?    @map("failed_at")
  failureReason      String?      @map("failure_reason")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  // ── Provider reimbursement tracking ──────────────────────
  provider                            String?   @map("provider")
  providerPnr                         String?   @map("provider_pnr")
  providerBookingReference            String?   @map("provider_booking_reference")
  providerRefundRequestId             String?   @map("provider_refund_request_id")
  providerSettlementReference         String?   @map("provider_settlement_reference")
  providerExpectedReimbursementAmount Decimal?  @map("provider_expected_reimbursement_amount") @db.Decimal(10, 2)
  actualProviderReimbursementAmount   Decimal?  @map("actual_provider_reimbursement_amount") @db.Decimal(10, 2)
  fareMindCancellationFee             Decimal?  @map("faremind_cancellation_fee") @db.Decimal(10, 2)

  // ── Separate status domains ─────────────────────────────
  customerRefundStatus                String?   @map("customer_refund_status") // CUSTOMER_REFUND_NOT_STARTED | CUSTOMER_REFUND_PENDING | CUSTOMER_REFUNDED | CUSTOMER_REFUND_FAILED
  providerReimbursementStatus         ProviderReimbursementStatus @default(NOT_STARTED) @map("provider_reimbursement_status")
  reconciliationStatus                ReconciliationStatus @default(RECONCILIATION_PENDING) @map("reconciliation_status")

  // ── Reimbursement monitoring ─────────────────────────────
  providerReimbursedAt                DateTime? @map("provider_reimbursed_at")
  reconciledAt                        DateTime? @map("reconciled_at")
  lastProviderStatusCheckAt           DateTime? @map("last_provider_status_check_at")
  nextProviderStatusCheckAt           DateTime? @map("next_provider_status_check_at")
  providerStatusCheckCount            Int       @default(0) @map("provider_status_check_count")

  // ── Linkage ─────────────────────────────────────────────
  supportTicketId                     String?   @map("support_ticket_id")
  idempotencyKey                      String?   @unique @map("idempotency_key")

  cancellation CancellationRecord? @relation(fields: [cancellationId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([cancellationId])
  @@index([status])
  @@index([providerReimbursementStatus, nextProviderStatusCheckAt])
  @@index([provider, providerRefundRequestId])
  @@index([providerPnr])
  @@index([supportTicketId])
  @@map("booking_refunds")
}

