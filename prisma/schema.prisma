// ═══════════════════════════════════════════════
// FareMind – Complete Database Schema
// PostgreSQL on Railway
// ═══════════════════════════════════════════════

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════
// USER & AUTH
// ═══════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  phone         String?
  avatar        String?
  role          UserRole  @default(USER)
  emailVerified Boolean   @default(false) @map("email_verified")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  // Relations
  bookings       Booking[]
  priceAlerts    PriceAlert[]
  searchHistory  SearchHistory[]
  sessions       Session[]
  notifications  Notification[]
  savedRoutes    SavedRoute[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

model Session {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

// ═══════════════════════════════════════════════
// FLIGHT SEARCH & CACHING
// ═══════════════════════════════════════════════

model SearchHistory {
  id              String   @id @default(cuid())
  userId          String?  @map("user_id")
  origin          String
  destination     String
  departureDate   DateTime @map("departure_date")
  returnDate      DateTime? @map("return_date")
  adults          Int      @default(1)
  children        Int      @default(0)
  infants         Int      @default(0)
  cabinClass      CabinClass @default(ECONOMY) @map("cabin_class")
  tripType        TripType   @default(ROUND_TRIP) @map("trip_type")
  resultsCount    Int?     @map("results_count")
  lowestPrice     Decimal? @map("lowest_price") @db.Decimal(10, 2)
  currency        String   @default("USD")
  searchDurationMs Int?    @map("search_duration_ms")
  createdAt       DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([origin, destination])
  @@index([departureDate])
  @@index([createdAt])
  @@map("search_history")
}

model CachedSearch {
  id            String   @id @default(cuid())
  cacheKey      String   @unique @map("cache_key")
  origin        String
  destination   String
  departureDate DateTime @map("departure_date")
  returnDate    DateTime? @map("return_date")
  cabinClass    CabinClass @default(ECONOMY) @map("cabin_class")
  resultsJson   Json     @map("results_json")
  providersMeta Json?    @map("providers_meta")
  expiresAt     DateTime @map("expires_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([cacheKey])
  @@index([expiresAt])
  @@index([origin, destination, departureDate])
  @@map("cached_searches")
}

// ═══════════════════════════════════════════════
// BOOKINGS
// ═══════════════════════════════════════════════

model Booking {
  id                  String        @id @default(cuid())
  userId              String        @map("user_id")
  provider            Provider
  providerBookingId   String?       @map("provider_booking_id")
  providerOfferId     String?       @map("provider_offer_id")
  pnr                 String?
  status              BookingStatus @default(PENDING)

  // Flight details (denormalized for fast display)
  airlineCode         String        @map("airline_code")
  airlineName         String        @map("airline_name")
  originAirport       String        @map("origin_airport")
  originCity          String        @map("origin_city")
  destinationAirport  String        @map("destination_airport")
  destinationCity     String        @map("destination_city")
  departureTime       DateTime      @map("departure_time")
  arrivalTime         DateTime      @map("arrival_time")
  totalDuration       Int           @map("total_duration") // minutes
  stops               Int           @default(0)
  cabinClass          CabinClass    @default(ECONOMY) @map("cabin_class")
  fareClass           String?       @map("fare_class")

  // Financial
  totalPrice          Decimal       @map("total_price") @db.Decimal(10, 2)
  baseFare            Decimal?      @map("base_fare") @db.Decimal(10, 2)
  taxes               Decimal?      @db.Decimal(10, 2)
  currency            String        @default("USD")
  platformFee         Decimal?      @map("platform_fee") @db.Decimal(10, 2)
  platformMargin      Decimal?      @map("platform_margin") @db.Decimal(5, 4) // e.g. 0.0350 = 3.5%

  // Fare rules
  refundable          Boolean       @default(false)
  changeable          Boolean       @default(false)
  cancellationFee     Decimal?      @map("cancellation_fee") @db.Decimal(10, 2)
  changeFee           Decimal?      @map("change_fee") @db.Decimal(10, 2)

  // Baggage
  carryOnBags         Int           @default(1) @map("carry_on_bags")
  checkedBags         Int           @default(0) @map("checked_bags")

  // Price tracking
  priceTracking       Boolean       @default(true) @map("price_tracking")
  currentTrackedPrice Decimal?      @map("current_tracked_price") @db.Decimal(10, 2)
  lastPriceCheckAt    DateTime?     @map("last_price_check_at")

  // Flight data snapshot (full provider response)
  flightDataSnapshot  Json?         @map("flight_data_snapshot")

  // Timestamps
  bookedAt            DateTime      @default(now()) @map("booked_at")
  cancelledAt         DateTime?     @map("cancelled_at")
  completedAt         DateTime?     @map("completed_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  // Relations
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  passengers          Passenger[]
  segments            FlightSegment[]
  priceHistory        PriceHistory[]
  priceAlerts         PriceAlert[]
  payments            Payment[]
  rebookings          Rebooking[]
  notifications       Notification[]

  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([pnr])
  @@index([departureTime])
  @@index([priceTracking, status])
  @@index([userId, status])
  @@map("bookings")
}

model Passenger {
  id            String        @id @default(cuid())
  bookingId     String        @map("booking_id")
  firstName     String        @map("first_name")
  lastName      String        @map("last_name")
  dateOfBirth   DateTime      @map("date_of_birth")
  gender        Gender
  email         String
  phone         String?
  type          PassengerType @default(ADULT)

  // Travel documents
  passportNumber    String?   @map("passport_number")
  passportExpiry    DateTime? @map("passport_expiry")
  nationality       String?
  issuingCountry    String?   @map("issuing_country")

  // Provider-specific passenger ID
  providerPassengerId String? @map("provider_passenger_id")

  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("passengers")
}

model FlightSegment {
  id              String   @id @default(cuid())
  bookingId       String   @map("booking_id")
  segmentOrder    Int      @map("segment_order")

  // Departure
  depAirport      String   @map("dep_airport")
  depAirportName  String?  @map("dep_airport_name")
  depCity         String?  @map("dep_city")
  depTime         DateTime @map("dep_time")
  depTerminal     String?  @map("dep_terminal")

  // Arrival
  arrAirport      String   @map("arr_airport")
  arrAirportName  String?  @map("arr_airport_name")
  arrCity         String?  @map("arr_city")
  arrTime         DateTime @map("arr_time")
  arrTerminal     String?  @map("arr_terminal")

  // Flight info
  airlineCode     String   @map("airline_code")
  airlineName     String?  @map("airline_name")
  flightNumber    String   @map("flight_number")
  duration        Int      // minutes
  aircraft        String?
  operatingCarrier String? @map("operating_carrier")

  createdAt       DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([depAirport, arrAirport])
  @@map("flight_segments")
}

// ═══════════════════════════════════════════════
// PRICE TRACKING & AI AGENT
// ═══════════════════════════════════════════════

model PriceHistory {
  id          String   @id @default(cuid())
  bookingId   String   @map("booking_id")
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  provider    Provider
  checkedAt   DateTime @default(now()) @map("checked_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([bookingId, checkedAt])
  @@index([checkedAt])
  @@map("price_history")
}

model PriceAlert {
  id            String          @id @default(cuid())
  bookingId     String          @map("booking_id")
  userId        String          @map("user_id")
  bookedPrice   Decimal         @map("booked_price") @db.Decimal(10, 2)
  currentPrice  Decimal         @map("current_price") @db.Decimal(10, 2)
  savings       Decimal         @db.Decimal(10, 2)
  percentDrop   Decimal         @map("percent_drop") @db.Decimal(5, 2)
  currency      String          @default("USD")
  status        PriceAlertStatus @default(NEW)
  detectedAt    DateTime        @default(now()) @map("detected_at")
  notifiedAt    DateTime?       @map("notified_at")
  actionedAt    DateTime?       @map("actioned_at")
  expiresAt     DateTime?       @map("expires_at")
  createdAt     DateTime        @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@map("price_alerts")
}

model PriceTrackingJob {
  id            String              @id @default(cuid())
  bookingId     String              @unique @map("booking_id")
  origin        String
  destination   String
  departureDate DateTime            @map("departure_date")
  cabinClass    CabinClass          @default(ECONOMY) @map("cabin_class")
  bookedPrice   Decimal             @map("booked_price") @db.Decimal(10, 2)
  currency      String              @default("USD")
  threshold     Decimal             @default(0.05) @db.Decimal(5, 4) // 5% default threshold
  status        TrackingJobStatus   @default(ACTIVE)
  lastRunAt     DateTime?           @map("last_run_at")
  nextRunAt     DateTime?           @map("next_run_at")
  runCount      Int                 @default(0) @map("run_count")
  errorCount    Int                 @default(0) @map("error_count")
  lastError     String?             @map("last_error")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  @@index([status])
  @@index([nextRunAt, status])
  @@map("price_tracking_jobs")
}

// ═══════════════════════════════════════════════
// REBOOKING ENGINE
// ═══════════════════════════════════════════════

model Rebooking {
  id                  String          @id @default(cuid())
  originalBookingId   String          @map("original_booking_id")
  newBookingId        String?         @map("new_booking_id")
  status              RebookingStatus @default(PENDING)

  // Pricing
  originalPrice       Decimal         @map("original_price") @db.Decimal(10, 2)
  newPrice            Decimal         @map("new_price") @db.Decimal(10, 2)
  cancellationCost    Decimal?        @map("cancellation_cost") @db.Decimal(10, 2)
  netSavings          Decimal         @map("net_savings") @db.Decimal(10, 2)
  currency            String          @default("USD")

  // Decision
  autoApproved        Boolean         @default(false) @map("auto_approved")
  userApprovedAt      DateTime?       @map("user_approved_at")
  reason              String?

  // Execution
  cancelledOriginalAt DateTime?       @map("cancelled_original_at")
  newBookingCreatedAt DateTime?       @map("new_booking_created_at")
  refundAmount        Decimal?        @map("refund_amount") @db.Decimal(10, 2)
  refundStatus        String?         @map("refund_status")

  // Timestamps
  initiatedAt         DateTime        @default(now()) @map("initiated_at")
  completedAt         DateTime?       @map("completed_at")
  failedAt            DateTime?       @map("failed_at")
  failureReason       String?         @map("failure_reason")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  originalBooking Booking @relation(fields: [originalBookingId], references: [id])

  @@index([originalBookingId])
  @@index([status])
  @@map("rebookings")
}

// ═══════════════════════════════════════════════
// PAYMENTS & LEDGER
// ═══════════════════════════════════════════════

model Payment {
  id                  String        @id @default(cuid())
  bookingId           String        @map("booking_id")
  stripePaymentId     String?       @unique @map("stripe_payment_id")
  stripeCustomerId    String?       @map("stripe_customer_id")
  type                PaymentType   @default(BOOKING)
  status              PaymentStatus @default(PENDING)

  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("USD")
  description         String?

  // Refund info
  refundedAmount      Decimal?      @map("refunded_amount") @db.Decimal(10, 2)
  refundedAt          DateTime?     @map("refunded_at")

  // Metadata
  metadata            Json?

  processedAt         DateTime?     @map("processed_at")
  failedAt            DateTime?     @map("failed_at")
  failureReason       String?       @map("failure_reason")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([stripePaymentId])
  @@index([status])
  @@map("payments")
}

model LedgerEntry {
  id          String      @id @default(cuid())
  type        LedgerType
  bookingId   String?     @map("booking_id")
  rebookingId String?     @map("rebooking_id")
  paymentId   String?     @map("payment_id")
  amount      Decimal     @db.Decimal(10, 2)
  currency    String      @default("USD")
  description String?
  metadata    Json?
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([type])
  @@index([createdAt])
  @@map("ledger_entries")
}

// ═══════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════

model Notification {
  id          String             @id @default(cuid())
  userId      String             @map("user_id")
  bookingId   String?            @map("booking_id")
  type        NotificationType
  channel     NotificationChannel @default(EMAIL)
  title       String
  body        String
  metadata    Json?
  status      NotificationStatus @default(PENDING)
  sentAt      DateTime?          @map("sent_at")
  readAt      DateTime?          @map("read_at")
  failedAt    DateTime?          @map("failed_at")
  failReason  String?            @map("fail_reason")
  createdAt   DateTime           @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, status])
  @@index([bookingId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

// ═══════════════════════════════════════════════
// SAVED ROUTES & WATCHLIST
// ═══════════════════════════════════════════════

model SavedRoute {
  id            String     @id @default(cuid())
  userId        String     @map("user_id")
  origin        String
  destination   String
  preferredDates String?   @map("preferred_dates") // JSON array of date ranges
  cabinClass    CabinClass @default(ECONOMY) @map("cabin_class")
  maxPrice      Decimal?   @map("max_price") @db.Decimal(10, 2)
  currency      String     @default("USD")
  alertEnabled  Boolean    @default(true) @map("alert_enabled")
  lastCheckedAt DateTime?  @map("last_checked_at")
  lowestSeen    Decimal?   @map("lowest_seen") @db.Decimal(10, 2)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([origin, destination])
  @@map("saved_routes")
}

// ═══════════════════════════════════════════════
// AIRLINE & AIRPORT REFERENCE DATA
// ═══════════════════════════════════════════════

model Airline {
  id        String  @id @default(cuid())
  iataCode  String  @unique @map("iata_code")
  name      String
  logoUrl   String? @map("logo_url")
  country   String?
  isActive  Boolean @default(true) @map("is_active")

  @@index([iataCode])
  @@map("airlines")
}

model Airport {
  id          String  @id @default(cuid())
  iataCode    String  @unique @map("iata_code")
  name        String
  city        String
  country     String
  countryCode String  @map("country_code")
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  timezone    String?
  isActive    Boolean @default(true) @map("is_active")

  @@index([iataCode])
  @@index([city])
  @@index([country])
  @@map("airports")
}

// ═══════════════════════════════════════════════
// ENUMS
// ═══════════════════════════════════════════════

enum Provider {
  DUFFEL
  AMADEUS
}

enum CabinClass {
  ECONOMY
  PREMIUM_ECONOMY
  BUSINESS
  FIRST
}

enum TripType {
  ONE_WAY
  ROUND_TRIP
  MULTI_CITY
}

enum BookingStatus {
  PENDING
  CONFIRMED
  TICKETED
  CANCELLED
  COMPLETED
  FAILED
  REBOOKED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PassengerType {
  ADULT
  CHILD
  INFANT
}

enum PriceAlertStatus {
  NEW
  NOTIFIED
  ACTED
  EXPIRED
  DISMISSED
}

enum TrackingJobStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

enum RebookingStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum PaymentType {
  BOOKING
  REBOOKING
  REFUND
  PLATFORM_FEE
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum LedgerType {
  BOOKING_PAYMENT
  REBOOKING_COST
  CANCELLATION_REFUND
  PLATFORM_FEE
  SAVINGS_CREDIT
}

enum NotificationType {
  BOOKING_CONFIRMATION
  BOOKING_CANCELLATION
  PRICE_DROP
  REBOOKING_OFFER
  REBOOKING_SUCCESS
  PRICE_ALERT
  SYSTEM
}

enum NotificationChannel {
  EMAIL
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum AdminRole {
  SUPER_ADMIN
  OPS_ADMIN
  SUPPORT
  FINANCE
  READ_ONLY
}

enum PartnerStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum AddonType {
  SEAT
  MEAL
  BAGGAGE
  PRICE_PROTECTION
  TRAVEL_INSURANCE
  OTHER
}

enum ChangeRequestType {
  DATE_CHANGE
  PASSENGER_UPDATE
  SEAT_CHANGE
  BAGGAGE_CHANGE
  UPGRADE
  NAME_CORRECTION
}

enum ChangeRequestStatus {
  NEW
  QUOTED
  CUSTOMER_PAYMENT_PENDING
  CONFIRMED
  REJECTED
  CANCELLED
}

enum CancellationStatus {
  CANCEL_REQUESTED
  IN_PROGRESS
  CANCELLED
  REFUND_PENDING
  REFUNDED
  FAILED
}

// ═══════════════════════════════════════════════
// ADMIN AUTH
// ═══════════════════════════════════════════════

model AdminUser {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String?   @map("password_hash")
  fullName           String    @map("full_name")
  role               AdminRole @default(SUPPORT)
  isActive           Boolean   @default(true) @map("is_active")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  lastLoginAt        DateTime? @map("last_login_at")
  lastLoginIp        String?   @map("last_login_ip")
  createdById        String?   @map("created_by_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  otps         AdminOtp[]
  sessions     AdminSession[]
  auditLogs    AuditLog[]
  supportNotes SupportNote[]

  @@index([email])
  @@map("admin_users")
}

model AdminOtp {
  id          String    @id @default(cuid())
  adminUserId String    @map("admin_user_id")
  otpHash     String    @map("otp_hash")
  expiresAt   DateTime  @map("expires_at")
  attempts    Int       @default(0)
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
  @@map("admin_otps")
}

model AdminSession {
  id           String   @id @default(cuid())
  adminUserId  String   @map("admin_user_id")
  token        String   @unique
  refreshToken String?  @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  createdAt    DateTime @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([token])
  @@map("admin_sessions")
}

// ═══════════════════════════════════════════════
// PARTNERS (B2B / AGENCIES)
// ═══════════════════════════════════════════════

model Partner {
  id            String        @id @default(cuid())
  name          String
  slug          String        @unique
  email         String        @unique
  phone         String?
  country       String?
  status        PartnerStatus @default(ACTIVE)
  apiKey        String?       @unique @map("api_key")
  creditLimit   Decimal?      @map("credit_limit") @db.Decimal(12, 2)
  creditBalance Decimal       @default(0) @map("credit_balance") @db.Decimal(12, 2)
  metadata      Json?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  users           PartnerUser[]
  commissionRules CommissionRule[]
  settlements     PartnerSettlement[]

  @@index([slug])
  @@index([status])
  @@map("partners")
}

model PartnerUser {
  id          String    @id @default(cuid())
  partnerId   String    @map("partner_id")
  email       String    @unique
  fullName    String    @map("full_name")
  role        String    @default("AGENT")
  isActive    Boolean   @default(true) @map("is_active")
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@map("partner_users")
}

// ═══════════════════════════════════════════════
// BOOKING EXTENSIONS
// ═══════════════════════════════════════════════

model BookingContact {
  id        String   @id @default(cuid())
  bookingId String   @unique @map("booking_id")
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  email     String
  phone     String?
  address   String?
  city      String?
  country   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([bookingId])
  @@map("booking_contacts")
}

model BookingAddon {
  id          String    @id @default(cuid())
  bookingId   String    @map("booking_id")
  type        AddonType
  description String?
  quantity    Int       @default(1)
  unitPrice   Decimal   @map("unit_price") @db.Decimal(10, 2)
  totalPrice  Decimal   @map("total_price") @db.Decimal(10, 2)
  currency    String    @default("USD")
  serviceId   String?   @map("service_id")
  seatNumber  String?   @map("seat_number")
  segmentRef  String?   @map("segment_ref")
  metadata    Json?
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([bookingId])
  @@map("booking_addons")
}

model BookingTicket {
  id           String    @id @default(cuid())
  bookingId    String    @map("booking_id")
  passengerId  String?   @map("passenger_id")
  ticketNumber String    @map("ticket_number")
  issuedAt     DateTime? @map("issued_at")
  eticketUrl   String?   @map("eticket_url")
  status       String    @default("ISSUED")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([ticketNumber])
  @@map("booking_tickets")
}

model BookingEvent {
  id          String   @id @default(cuid())
  bookingId   String   @map("booking_id")
  eventType   String   @map("event_type")
  title       String
  description String?
  metadata    Json?
  actorType   String?  @map("actor_type")
  actorId     String?  @map("actor_id")
  actorName   String?  @map("actor_name")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([bookingId, createdAt])
  @@map("booking_events")
}

// ═══════════════════════════════════════════════
// CHANGE REQUESTS
// ═══════════════════════════════════════════════

model ChangeRequest {
  id               String              @id @default(cuid())
  bookingId        String              @map("booking_id")
  type             ChangeRequestType
  status           ChangeRequestStatus @default(NEW)
  requestedBy      String              @map("requested_by")
  assignedTo       String?             @map("assigned_to")
  originalData     Json?               @map("original_data")
  requestedData    Json?               @map("requested_data")
  fareDifference   Decimal?            @map("fare_difference") @db.Decimal(10, 2)
  penalties        Decimal?            @db.Decimal(10, 2)
  totalCost        Decimal?            @map("total_cost") @db.Decimal(10, 2)
  currency         String              @default("USD")
  providerQuoteId  String?             @map("provider_quote_id")
  providerResponse Json?               @map("provider_response")
  paymentIntentId  String?             @map("payment_intent_id")
  paidAt           DateTime?           @map("paid_at")
  notes            String?
  rejectionReason  String?             @map("rejection_reason")
  expiresAt        DateTime?           @map("expires_at")
  confirmedAt      DateTime?           @map("confirmed_at")
  rejectedAt       DateTime?           @map("rejected_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  @@index([bookingId])
  @@index([status])
  @@index([assignedTo])
  @@map("change_requests")
}

// ═══════════════════════════════════════════════
// CANCELLATIONS
// ═══════════════════════════════════════════════

model CancellationRecord {
  id               String             @id @default(cuid())
  bookingId        String             @unique @map("booking_id")
  status           CancellationStatus @default(CANCEL_REQUESTED)
  requestedBy      String             @map("requested_by")
  assignedTo       String?            @map("assigned_to")
  originalAmount   Decimal            @map("original_amount") @db.Decimal(10, 2)
  penaltyAmount    Decimal?           @map("penalty_amount") @db.Decimal(10, 2)
  refundAmount     Decimal?           @map("refund_amount") @db.Decimal(10, 2)
  currency         String             @default("USD")
  providerCancelId String?            @map("provider_cancel_id")
  providerResponse Json?              @map("provider_response")
  stripeRefundId   String?            @map("stripe_refund_id")
  notes            String?
  cancelledAt      DateTime?          @map("cancelled_at")
  refundedAt       DateTime?          @map("refunded_at")
  failedAt         DateTime?          @map("failed_at")
  failureReason    String?            @map("failure_reason")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@index([status])
  @@index([assignedTo])
  @@map("cancellations")
}

// ═══════════════════════════════════════════════
// SUPPORT & AUDIT
// ═══════════════════════════════════════════════

model SupportNote {
  id          String    @id @default(cuid())
  bookingId   String    @map("booking_id")
  adminUserId String    @map("admin_user_id")
  note        String
  isInternal  Boolean   @default(true) @map("is_internal")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id])

  @@index([bookingId])
  @@index([adminUserId])
  @@map("support_notes")
}

model AuditLog {
  id          String    @id @default(cuid())
  adminUserId String?   @map("admin_user_id")
  action      String
  entityType  String    @map("entity_type")
  entityId    String?   @map("entity_id")
  before      Json?
  after       Json?
  metadata    Json?
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  adminUser AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════════
// PROVIDER SYNC
// ═══════════════════════════════════════════════

model ProviderSync {
  id              String   @id @default(cuid())
  bookingId       String   @map("booking_id")
  provider        Provider
  providerOrderId String?  @map("provider_order_id")
  status          String   @default("SYNCED")
  lastSyncAt      DateTime? @map("last_sync_at")
  lastError       String?  @map("last_error")
  retryCount      Int      @default(0) @map("retry_count")
  rawResponse     Json?    @map("raw_response")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([bookingId])
  @@index([status])
  @@index([provider, status])
  @@map("provider_sync")
}

// ═══════════════════════════════════════════════
// COMMISSIONS & SETTLEMENTS
// ═══════════════════════════════════════════════

model CommissionRule {
  id        String   @id @default(cuid())
  partnerId String   @map("partner_id")
  airline   String?
  route     String?
  fareClass String?  @map("fare_class")
  rateType  String   @default("PERCENT")
  rate      Decimal  @db.Decimal(8, 4)
  currency  String   @default("USD")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@map("commission_rules")
}

model PartnerSettlement {
  id            String   @id @default(cuid())
  partnerId     String   @map("partner_id")
  periodStart   DateTime @map("period_start")
  periodEnd     DateTime @map("period_end")
  bookingsCount Int      @default(0) @map("bookings_count")
  grossRevenue  Decimal  @map("gross_revenue") @db.Decimal(12, 2)
  commission    Decimal  @db.Decimal(12, 2)
  netPayable    Decimal  @map("net_payable") @db.Decimal(12, 2)
  currency      String   @default("USD")
  status        String   @default("PENDING")
  paidAt        DateTime? @map("paid_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  partner Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
  @@index([status])
  @@map("partner_settlements")
}

// ═══════════════════════════════════════════════
// FARE AI SCORES
// ═══════════════════════════════════════════════

model FareAiScore {
  id              String   @id @default(cuid())

  // Fare identification
  fareOptionId    String   @map("fare_option_id")
  offerId         String   @map("offer_id")
  fareName        String   @map("fare_name")
  cabin           String
  totalPrice      Decimal  @map("total_price") @db.Decimal(10, 2)
  currency        String   @default("USD")

  // Sub-scores (0.0 – 1.0)
  priceScore      Decimal  @map("price_score")      @db.Decimal(5, 4)
  durationScore   Decimal  @map("duration_score")   @db.Decimal(5, 4)
  stopsScore      Decimal  @map("stops_score")      @db.Decimal(5, 4)
  baggageScore    Decimal  @map("baggage_score")    @db.Decimal(5, 4)
  refundScore     Decimal  @map("refund_score")     @db.Decimal(5, 4)
  changeScore     Decimal  @map("change_score")     @db.Decimal(5, 4)
  seatScore       Decimal  @map("seat_score")       @db.Decimal(5, 4)
  layoverScore    Decimal  @map("layover_score")    @db.Decimal(5, 4)
  predictionScore Decimal  @map("prediction_score") @db.Decimal(5, 4)

  // Final score (0.00 – 100.00)
  finalScore      Decimal  @map("final_score") @db.Decimal(6, 2)

  // Classification
  explanation     String
  badgesJson      Json     @map("badges_json")

  computedAt      DateTime @default(now()) @map("computed_at")

  @@index([offerId])
  @@index([fareOptionId])
  @@index([finalScore])
  @@map("fare_ai_scores")
}
