// ═══════════════════════════════════════════════
// FareMind – Complete Database Schema
// PostgreSQL on Railway
// ═══════════════════════════════════════════════

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ═══════════════════════════════════════════════
// USER & AUTH
// ═══════════════════════════════════════════════

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  firstName     String    @map("first_name")
  lastName      String    @map("last_name")
  phone         String?
  avatar        String?
  role          UserRole  @default(USER)
  emailVerified Boolean   @default(false) @map("email_verified")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")

  // Relations
  bookings        Booking[]
  masterBookings  MasterBooking[]
  priceAlerts     PriceAlert[]
  searchHistory   SearchHistory[]
  sessions        Session[]
  notifications   Notification[]
  savedRoutes     SavedRoute[]
  paymentMethods  PaymentMethod[]
  servicePayments ServicePayment[]
  limitOrders     LimitOrder[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
  FAREMIND_AGENT
}

model Session {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  token          String   @unique
  expiresAt      DateTime @map("expires_at")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("sessions")
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  otpHash   String   @map("otp_hash")
  expiresAt DateTime @map("expires_at")
  isUsed    Boolean  @default(false) @map("is_used")
  attempts  Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("otp_codes")
}

// ═══════════════════════════════════════════════
// FLIGHT SEARCH & CACHING
// ═══════════════════════════════════════════════

model SearchHistory {
  id              String     @id @default(cuid())
  userId          String?    @map("user_id")
  origin          String
  destination     String
  departureDate   DateTime   @map("departure_date")
  returnDate      DateTime?  @map("return_date")
  adults          Int        @default(1)
  children        Int        @default(0)
  infants         Int        @default(0)
  cabinClass      CabinClass @default(ECONOMY) @map("cabin_class")
  tripType        TripType   @default(ROUND_TRIP) @map("trip_type")
  resultsCount    Int?       @map("results_count")
  lowestPrice     Decimal?   @map("lowest_price") @db.Decimal(10, 2)
  currency        String     @default("USD")
  searchDurationMs Int?      @map("search_duration_ms")
  createdAt       DateTime   @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([origin, destination])
  @@index([departureDate])
  @@index([createdAt])
  @@map("search_history")
}

model CachedSearch {
  id            String     @id @default(cuid())
  cacheKey      String     @unique @map("cache_key")
  origin        String
  destination   String
  departureDate DateTime   @map("departure_date")
  returnDate    DateTime?  @map("return_date")
  cabinClass    CabinClass @default(ECONOMY) @map("cabin_class")
  resultsJson   Json       @map("results_json")
  providersMeta Json?      @map("providers_meta")
  expiresAt     DateTime   @map("expires_at")
  createdAt     DateTime   @default(now()) @map("created_at")

  @@index([cacheKey])
  @@index([expiresAt])
  @@index([origin, destination, departureDate])
  @@map("cached_searches")
}

// ═══════════════════════════════════════════════
// LEGACY BOOKINGS (kept for price-tracking engine)
// ═══════════════════════════════════════════════

model Booking {
  id                  String        @id @default(cuid())
  userId              String?       @map("user_id")
  provider            Provider
  providerBookingId   String?       @map("provider_booking_id")
  providerOfferId     String?       @map("provider_offer_id")
  pnr                 String?
  status              BookingStatus @default(PENDING)

  airlineCode         String        @map("airline_code")
  airlineName         String        @map("airline_name")
  originAirport       String        @map("origin_airport")
  originCity          String        @map("origin_city")
  destinationAirport  String        @map("destination_airport")
  destinationCity     String        @map("destination_city")
  departureTime       DateTime      @map("departure_time")
  arrivalTime         DateTime      @map("arrival_time")
  totalDuration       Int           @map("total_duration")
  stops               Int           @default(0)
  cabinClass          CabinClass    @default(ECONOMY) @map("cabin_class")
  fareClass           String?       @map("fare_class")

  totalPrice          Decimal       @map("total_price") @db.Decimal(10, 2)
  baseFare            Decimal?      @map("base_fare") @db.Decimal(10, 2)
  taxes               Decimal?      @db.Decimal(10, 2)
  currency            String        @default("USD")
  platformFee         Decimal?      @map("platform_fee") @db.Decimal(10, 2)
  platformMargin      Decimal?      @map("platform_margin") @db.Decimal(5, 4)

  refundable          Boolean       @default(false)
  changeable          Boolean       @default(false)
  cancellationFee     Decimal?      @map("cancellation_fee") @db.Decimal(10, 2)
  changeFee           Decimal?      @map("change_fee") @db.Decimal(10, 2)

  carryOnBags         Int           @default(1) @map("carry_on_bags")
  checkedBags         Int           @default(0) @map("checked_bags")

  priceTracking       Boolean       @default(true) @map("price_tracking")
  currentTrackedPrice Decimal?      @map("current_tracked_price") @db.Decimal(10, 2)
  lastPriceCheckAt    DateTime?     @map("last_price_check_at")

  flightDataSnapshot  Json?         @map("flight_data_snapshot")

  bookedAt            DateTime      @default(now()) @map("booked_at")
  cancelledAt         DateTime?     @map("cancelled_at")
  completedAt         DateTime?     @map("completed_at")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  user                User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  passengers          Passenger[]
  segments            FlightSegment[]
  priceHistory        PriceHistory[]
  priceAlerts         PriceAlert[]
  payments            Payment[]
  rebookings          Rebooking[]
  notifications       Notification[]

  @@index([userId])
  @@index([status])
  @@index([provider])
  @@index([pnr])
  @@index([departureTime])
  @@index([priceTracking, status])
  @@index([userId, status])
  @@map("bookings")
}

model Passenger {
  id                  String        @id @default(cuid())
  bookingId           String        @map("booking_id")
  firstName           String        @map("first_name")
  lastName            String        @map("last_name")
  dateOfBirth         DateTime      @map("date_of_birth")
  gender              Gender
  email               String
  phone               String?
  type                PassengerType @default(ADULT)
  passportNumber      String?       @map("passport_number")
  passportExpiry      DateTime?     @map("passport_expiry")
  nationality         String?
  issuingCountry      String?       @map("issuing_country")
  providerPassengerId String?       @map("provider_passenger_id")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("passengers")
}

model FlightSegment {
  id              String   @id @default(cuid())
  bookingId       String   @map("booking_id")
  segmentOrder    Int      @map("segment_order")
  depAirport      String   @map("dep_airport")
  depAirportName  String?  @map("dep_airport_name")
  depCity         String?  @map("dep_city")
  depTime         DateTime @map("dep_time")
  depTerminal     String?  @map("dep_terminal")
  arrAirport      String   @map("arr_airport")
  arrAirportName  String?  @map("arr_airport_name")
  arrCity         String?  @map("arr_city")
  arrTime         DateTime @map("arr_time")
  arrTerminal     String?  @map("arr_terminal")
  airlineCode     String   @map("airline_code")
  airlineName     String?  @map("airline_name")
  flightNumber    String   @map("flight_number")
  duration        Int
  aircraft        String?
  operatingCarrier String? @map("operating_carrier")
  createdAt       DateTime @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([depAirport, arrAirport])
  @@map("flight_segments")
}

// ═══════════════════════════════════════════════
// PRICE TRACKING & AI AGENT
// ═══════════════════════════════════════════════

model PriceHistory {
  id          String   @id @default(cuid())
  bookingId   String   @map("booking_id")
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  provider    Provider
  checkedAt   DateTime @default(now()) @map("checked_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([bookingId, checkedAt])
  @@index([checkedAt])
  @@map("price_history")
}

model PriceAlert {
  id            String           @id @default(cuid())
  bookingId     String           @map("booking_id")
  userId        String           @map("user_id")
  bookedPrice   Decimal          @map("booked_price") @db.Decimal(10, 2)
  currentPrice  Decimal          @map("current_price") @db.Decimal(10, 2)
  savings       Decimal          @db.Decimal(10, 2)
  percentDrop   Decimal          @map("percent_drop") @db.Decimal(5, 2)
  currency      String           @default("USD")
  status        PriceAlertStatus @default(NEW)
  detectedAt    DateTime         @default(now()) @map("detected_at")
  notifiedAt    DateTime?        @map("notified_at")
  actionedAt    DateTime?        @map("actioned_at")
  expiresAt     DateTime?        @map("expires_at")
  createdAt     DateTime         @default(now()) @map("created_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@map("price_alerts")
}

model PriceTrackingJob {
  id            String            @id @default(cuid())
  bookingId     String            @unique @map("booking_id")
  origin        String
  destination   String
  departureDate DateTime          @map("departure_date")
  cabinClass    CabinClass        @default(ECONOMY) @map("cabin_class")
  bookedPrice   Decimal           @map("booked_price") @db.Decimal(10, 2)
  currency      String            @default("USD")
  threshold     Decimal           @default(0.05) @db.Decimal(5, 4)
  status        TrackingJobStatus @default(ACTIVE)
  lastRunAt     DateTime?         @map("last_run_at")
  nextRunAt     DateTime?         @map("next_run_at")
  runCount      Int               @default(0) @map("run_count")
  errorCount    Int               @default(0) @map("error_count")
  lastError     String?           @map("last_error")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([status])
  @@index([nextRunAt, status])
  @@map("price_tracking_jobs")
}

// ═══════════════════════════════════════════════
// REBOOKING ENGINE
// ═══════════════════════════════════════════════

model Rebooking {
  id                  String          @id @default(cuid())
  originalBookingId   String          @map("original_booking_id")
  newBookingId        String?         @map("new_booking_id")
  status              RebookingStatus @default(PENDING)
  originalPrice       Decimal         @map("original_price") @db.Decimal(10, 2)
  newPrice            Decimal         @map("new_price") @db.Decimal(10, 2)
  cancellationCost    Decimal?        @map("cancellation_cost") @db.Decimal(10, 2)
  netSavings          Decimal         @map("net_savings") @db.Decimal(10, 2)
  currency            String          @default("USD")
  autoApproved        Boolean         @default(false) @map("auto_approved")
  userApprovedAt      DateTime?       @map("user_approved_at")
  reason              String?
  cancelledOriginalAt DateTime?       @map("cancelled_original_at")
  newBookingCreatedAt DateTime?       @map("new_booking_created_at")
  refundAmount        Decimal?        @map("refund_amount") @db.Decimal(10, 2)
  refundStatus        String?         @map("refund_status")
  initiatedAt         DateTime        @default(now()) @map("initiated_at")
  completedAt         DateTime?       @map("completed_at")
  failedAt            DateTime?       @map("failed_at")
  failureReason       String?         @map("failure_reason")
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  originalBooking Booking @relation(fields: [originalBookingId], references: [id])

  @@index([originalBookingId])
  @@index([status])
  @@map("rebookings")
}

// ═══════════════════════════════════════════════
// LEGACY PAYMENTS & LEDGER
// ═══════════════════════════════════════════════

model Payment {
  id                  String        @id @default(cuid())
  bookingId           String        @map("booking_id")
  stripePaymentId     String?       @unique @map("stripe_payment_id")
  stripeCustomerId    String?       @map("stripe_customer_id")
  type                PaymentType   @default(BOOKING)
  status              PaymentStatus @default(PENDING)
  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("USD")
  description         String?
  refundedAmount      Decimal?      @map("refunded_amount") @db.Decimal(10, 2)
  refundedAt          DateTime?     @map("refunded_at")
  metadata            Json?
  processedAt         DateTime?     @map("processed_at")
  failedAt            DateTime?     @map("failed_at")
  failureReason       String?       @map("failure_reason")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([stripePaymentId])
  @@index([status])
  @@map("payments")
}

model LedgerEntry {
  id          String      @id @default(cuid())
  type        LedgerType
  bookingId   String?     @map("booking_id")
  rebookingId String?     @map("rebooking_id")
  paymentId   String?     @map("payment_id")
  amount      Decimal     @db.Decimal(10, 2)
  currency    String      @default("USD")
  description String?
  metadata    Json?
  createdAt   DateTime    @default(now()) @map("created_at")

  @@index([bookingId])
  @@index([type])
  @@index([createdAt])
  @@map("ledger_entries")
}

// ═══════════════════════════════════════════════
// NOTIFICATIONS
// ═══════════════════════════════════════════════

model Notification {
  id          String              @id @default(cuid())
  userId      String              @map("user_id")
  bookingId   String?             @map("booking_id")
  type        NotificationType
  channel     NotificationChannel @default(EMAIL)
  title       String
  body        String
  metadata    Json?
  status      NotificationStatus  @default(PENDING)
  sentAt      DateTime?           @map("sent_at")
  readAt      DateTime?           @map("read_at")
  failedAt    DateTime?           @map("failed_at")
  failReason  String?             @map("fail_reason")
  createdAt   DateTime            @default(now()) @map("created_at")

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, status])
  @@index([bookingId])
  @@index([status])
  @@index([createdAt])
  @@map("notifications")
}

// ═══════════════════════════════════════════════
// SAVED ROUTES & WATCHLIST
// ═══════════════════════════════════════════════

model SavedRoute {
  id             String     @id @default(cuid())
  userId         String     @map("user_id")
  origin         String
  destination    String
  preferredDates String?    @map("preferred_dates")
  cabinClass     CabinClass @default(ECONOMY) @map("cabin_class")
  maxPrice       Decimal?   @map("max_price") @db.Decimal(10, 2)
  currency       String     @default("USD")
  alertEnabled   Boolean    @default(true) @map("alert_enabled")
  lastCheckedAt  DateTime?  @map("last_checked_at")
  lowestSeen     Decimal?   @map("lowest_seen") @db.Decimal(10, 2)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([origin, destination])
  @@map("saved_routes")
}

// ═══════════════════════════════════════════════
// AIRLINE & AIRPORT REFERENCE DATA
// ═══════════════════════════════════════════════

model Airline {
  id        String  @id @default(cuid())
  iataCode  String  @unique @map("iata_code")
  name      String
  logoUrl   String? @map("logo_url")
  country   String?
  isActive  Boolean @default(true) @map("is_active")

  @@index([iataCode])
  @@map("airlines")
}

model Airport {
  id          String   @id @default(cuid())
  iataCode    String   @unique @map("iata_code")
  name        String
  city        String
  country     String
  countryCode String   @map("country_code")
  latitude    Decimal? @db.Decimal(10, 7)
  longitude   Decimal? @db.Decimal(10, 7)
  timezone    String?
  isActive    Boolean  @default(true) @map("is_active")

  @@index([iataCode])
  @@index([city])
  @@index([country])
  @@map("airports")
}

// ═══════════════════════════════════════════════
// ═══════════════════════════════════════════════
// MASTER BOOKINGS — Professional OTA Data Model
// ═══════════════════════════════════════════════
// ═══════════════════════════════════════════════

model MasterBooking {
  id                     String             @id @default(cuid())
  masterBookingReference String             @unique @map("master_booking_reference")
  masterPnr              String?            @map("master_pnr")

  // Customer
  customerEmail          String             @map("customer_email")
  customerName           String             @map("customer_name")
  userId                 String?            @map("user_id")

  // Trip
  tripType               MbTripType         @default(ONE_WAY) @map("trip_type")
  originAirport          String             @map("origin_airport")
  originCity             String             @map("origin_city")
  originCountry          String?            @map("origin_country")
  destinationAirport     String             @map("destination_airport")
  destinationCity        String             @map("destination_city")
  destinationCountry     String?            @map("destination_country")
  departureDate          DateTime           @map("departure_date")
  returnDate             DateTime?          @map("return_date")

  // Status
  bookingStatus          MbBookingStatus    @default(CREATED) @map("booking_status")
  paymentStatus          MbPaymentStatus    @default(PENDING) @map("payment_status")
  ticketingStatus        MbTicketingStatus  @default(NOT_STARTED) @map("ticketing_status")

  // Financial — Customer Grand Total
  totalAmount            Decimal            @map("total_amount") @db.Decimal(10, 2)
  currency               String             @default("USD")

  // Financial — Provider Settlement
  providerPayableTotal   Decimal?           @map("provider_payable_total") @db.Decimal(10, 2)
  providerCurrency       String?            @map("provider_currency")
  providerOfferId        String?            @map("provider_offer_id")
  providerOrderId        String?            @map("provider_order_id")

  // Financial — FareMind Revenue
  markupAmount           Decimal?           @map("markup_amount") @db.Decimal(10, 2)
  serviceFeeAmount       Decimal?           @map("service_fee_amount") @db.Decimal(10, 2)
  fareMindRevenueTotal   Decimal?           @map("faremind_revenue_total") @db.Decimal(10, 2)

  // Financial — Third-Party Vendor Payables
  priceProtectionAmount  Decimal?           @map("price_protection_amount") @db.Decimal(10, 2)
  travelInsuranceAmount  Decimal?           @map("travel_insurance_amount") @db.Decimal(10, 2)
  thirdPartyPayableTotal Decimal?           @map("third_party_payable_total") @db.Decimal(10, 2)

  // Financial — Seat/Ancillary Service Totals
  seatServiceTotal       Decimal?           @map("seat_service_total") @db.Decimal(10, 2)

  // Provider
  primaryProvider        String             @default("duffel") @map("primary_provider")

  rawProviderPayload     Json?              @map("raw_provider_payload")
  providerCapabilities   Json?              @map("provider_capabilities")

  // Offer lifecycle timestamps (from Duffel)
  offerProvidedAt        DateTime?          @map("offer_provided_at")
  offerExpiresAt         DateTime?          @map("offer_expires_at")

  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  // PNR strategy fields
  pnrStrategy            PnrStrategy?       @map("pnr_strategy")
  isSplitTicket          Boolean            @default(false) @map("is_split_ticket")
  isSelfTransfer         Boolean            @default(false) @map("is_self_transfer")
  connectionProtStatus   ConnProtStatus     @default(UNKNOWN) @map("connection_prot_status")
  providerMix            String?            @map("provider_mix")
  pnrCount               Int                @default(1) @map("pnr_count")
  riskLabel              String?            @map("risk_label")
  riskExplanation        String?            @map("risk_explanation")

  // Relations
  user                   User?              @relation(fields: [userId], references: [id])
  pnrs                   BookingPnr[]
  journeys               BookingJourney[]
  segments               BookingSegment[]
  passengers             BookingPassenger[]
  tickets                BookingTicket[]
  seats                  BookingSeat[]
  meals                  BookingMeal[]
  baggage                BookingBaggage[]
  addons                 BookingAddon[]
  payments               BookingPayment[]
  events                 BookingEvent[]
  notes                  BookingNote[]
  providerPayloads       BookingProviderPayload[]
  changeRequests         ChangeRequest[]
  cancellations          CancellationRecord[]
  passengerUpdates       BookingPassengerUpdate[]
  providerSyncs          ProviderSync[]
  commercialCharges      BookingCommercialCharge[]
  ancillaries            BookingAncillary[]
  servicePayments        ServicePayment[]

  // Agent booking ownership
  createdByRole          String?            @map("created_by_role")       // 'AGENT' | 'CUSTOMER' | null
  agentUserId            String?            @map("agent_user_id")
  agentName              String?            @map("agent_name")
  agentEmail             String?            @map("agent_email")

  // Provider Support (Duffel Assistant) — added for internal support tool
  duffelCustomerUserId         String?    @map("duffel_customer_user_id")
  lastProviderSupportOpenedAt  DateTime?  @map("last_provider_support_opened_at")
  lastProviderSupportOpenedBy  String?    @map("last_provider_support_opened_by")
  providerSupportSessionCount  Int        @default(0) @map("provider_support_session_count")

  // ── Mystifly / Provider Lifecycle Fields ──
  searchFareSourceCode         String?    @map("search_fare_source_code")      // Original FSC from search
  revalidatedFareSourceCode    String?    @map("revalidated_fare_source_code") // FSC returned by revalidation
  mystiflyMfRef                String?    @map("mystifly_mf_ref")              // Mystifly booking UniqueID
  providerBookingStatus        String?    @map("provider_booking_status")      // Raw provider status text
  providerEnvironment          String?    @map("provider_environment")         // 'Test' | 'Production'
  providerApiVersion           String?    @map("provider_api_version")         // 'v1' | 'v2' | 'v2.2'
  bookingAttemptKey            String?    @unique @map("booking_attempt_key")  // Idempotency key

  // Relations — reconciliation
  revalidationSnapshots        RevalidationSnapshot[]
  bookingAttempts              BookingAttempt[]
  ticketingReconciliations     TicketingReconciliation[]
  postTicketingRequests        PostTicketingRequest[]
  limitOrderMatches            LimitOrderMatch[]

  @@index([masterBookingReference])
  @@index([masterPnr])
  @@index([customerEmail])
  @@index([userId])
  @@index([departureDate])
  @@index([bookingStatus])
  @@index([agentUserId])
  @@index([mystiflyMfRef])
  @@index([bookingAttemptKey])
  @@map("master_bookings")
}

// ── PNR Records ───────────────────────────────

model BookingPnr {
  id               String    @id @default(cuid())
  bookingId        String    @map("booking_id")
  pnrCode          String    @map("pnr_code")
  pnrType          PnrType   @default(AIRLINE_PNR) @map("pnr_type")
  journeyDirection PnrDir    @default(ALL) @map("journey_direction")
  isPrimary        Boolean   @default(false) @map("is_primary")
  status           PnrStatus @default(ACTIVE) @map("status")
  provider         String?
  providerOrderId  String?   @map("provider_order_id")
  airlineCode      String?   @map("airline_code")
  airlineName      String?   @map("airline_name")
  displayLabel     String?   @map("display_label")

  // ── Fare Rules (stored at booking time) ──
  refundable       Boolean   @default(false)
  changeable       Boolean   @default(false)
  cancellationFee  Decimal?  @map("cancellation_fee") @db.Decimal(10, 2)
  changeFee        Decimal?  @map("change_fee") @db.Decimal(10, 2)
  seatSelection    String?   @map("seat_selection")
  seatSelectionFee Decimal?  @map("seat_selection_fee") @db.Decimal(10, 2)
  milesEarning     String?   @map("miles_earning")
  fareRulesJson    Json?     @map("fare_rules_json")

  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  booking  MasterBooking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  segments BookingSegment[]
  tickets  BookingTicket[]

  @@index([bookingId])
  @@index([pnrCode])
  @@map("booking_pnrs")
}

// ── Journeys (Outbound / Return) ──────────────

model BookingJourney {
  id                  String         @id @default(cuid())
  bookingId           String         @map("booking_id")
  direction           JourneyDir     @map("direction")
  journeyOrder        Int            @default(0) @map("journey_order")
  originAirport       String         @map("origin_airport")
  originCity          String         @map("origin_city")
  originCountry       String?        @map("origin_country")
  destinationAirport  String         @map("destination_airport")
  destinationCity     String         @map("destination_city")
  destinationCountry  String?        @map("destination_country")
  departureDateTime   DateTime       @map("departure_datetime")
  arrivalDateTime     DateTime       @map("arrival_datetime")
  totalDurationMinutes Int           @map("total_duration_minutes")
  totalStops          Int            @default(0) @map("total_stops")
  primaryAirline      String?        @map("primary_airline")
  cabinSummary        String?        @map("cabin_summary")
  journeyStatus       String         @default("confirmed") @map("journey_status")
  totalFare           Decimal?       @map("total_fare") @db.Decimal(10, 2)
  fareCurrency        String?        @map("fare_currency")
  pnrCount            Int            @default(1) @map("pnr_count")
  isSplitJourney      Boolean        @default(false) @map("is_split_journey")
  journeyProtStatus   ConnProtStatus @default(UNKNOWN) @map("journey_prot_status")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  booking  MasterBooking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  segments BookingSegment[]
  seats    BookingSeat[]
  meals    BookingMeal[]
  baggage  BookingBaggage[]
  addons   BookingAddon[]
  tickets  BookingTicket[]

  @@index([bookingId])
  @@map("booking_journeys")
}

// ── Segments (individual hops) ────────────────

model BookingSegment {
  id                    String   @id @default(cuid())
  bookingId             String   @map("booking_id")
  journeyId             String   @map("journey_id")
  pnrId                 String?  @map("pnr_id")
  direction             JourneyDir @map("direction")
  segmentOrder          Int      @map("segment_order")
  providerSegmentId     String?  @map("provider_segment_id")
  providerOfferId       String?  @map("provider_offer_id")
  providerOrderId       String?  @map("provider_order_id")

  airlineCode           String   @map("airline_code")
  airlineName           String   @map("airline_name")
  marketingCarrierCode  String?  @map("marketing_carrier_code")
  operatingAirlineCode  String?  @map("operating_airline_code")
  operatingAirlineName  String?  @map("operating_airline_name")
  flightNumber          String   @map("flight_number")
  isCodeshare           Boolean  @default(false) @map("is_codeshare")
  isSelfTransferSegment Boolean  @default(false) @map("is_self_transfer_segment")
  aircraftType          String?  @map("aircraft_type")
  cabin                 String   @default("ECONOMY")
  fareClass             String?  @map("fare_class")

  originAirport         String   @map("origin_airport")
  originCity            String   @map("origin_city")
  originCountry         String?  @map("origin_country")
  originTerminal        String?  @map("origin_terminal")
  originGate            String?  @map("origin_gate")
  destinationAirport    String   @map("destination_airport")
  destinationCity       String   @map("destination_city")
  destinationCountry    String?  @map("destination_country")
  destinationTerminal   String?  @map("destination_terminal")
  destinationGate       String?  @map("destination_gate")

  departureDateTime     DateTime @map("departure_datetime")
  arrivalDateTime       DateTime @map("arrival_datetime")
  durationMinutes       Int      @map("duration_minutes")

  layoverAfterMinutes   Int?     @map("layover_after_minutes")
  layoverAirport        String?  @map("layover_airport")
  layoverCity           String?  @map("layover_city")
  layoverCountry        String?  @map("layover_country")

  segmentStatus         String   @default("confirmed") @map("segment_status")
  rawSegmentPayload     Json?    @map("raw_segment_payload")

  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  booking  MasterBooking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  journey  BookingJourney   @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  pnr      BookingPnr?      @relation(fields: [pnrId], references: [id])
  tickets  BookingTicket[]
  seats    BookingSeat[]
  meals    BookingMeal[]
  coupons  TicketCoupon[]

  @@index([bookingId])
  @@index([journeyId])
  @@map("booking_segments")
}

// ── Passengers ────────────────────────────────

model BookingPassenger {
  id                  String   @id @default(cuid())
  bookingId           String   @map("booking_id")
  passengerOrder      Int      @default(0) @map("passenger_order")
  passengerType       String   @default("adult") @map("passenger_type")
  firstName           String   @map("first_name")
  middleName          String?  @map("middle_name")
  lastName            String   @map("last_name")
  email               String?
  phone               String?
  gender              String?
  dateOfBirth         DateTime? @map("date_of_birth")
  nationality         String?
  passportCountry     String?  @map("passport_country")
  passportNumber      String?  @map("passport_number")
  passportExpiry      DateTime? @map("passport_expiry")
  providerPassengerId String?  @map("provider_passenger_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  booking  MasterBooking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tickets  BookingTicket[]
  seats    BookingSeat[]
  meals    BookingMeal[]
  baggage  BookingBaggage[]
  addons   BookingAddon[]
  coupons  TicketCoupon[]

  @@index([bookingId])
  @@index([bookingId, lastName])
  @@map("booking_passengers")
}

// ── Tickets ───────────────────────────────────

model BookingTicket {
  id                   String       @id @default(cuid())
  bookingId            String       @map("booking_id")
  passengerId          String       @map("passenger_id")
  journeyId            String?      @map("journey_id")
  segmentId            String?      @map("segment_id")
  pnrId                String?      @map("pnr_id")
  ticketNumber         String?      @map("ticket_number")
  eTicketNumber        String?      @map("e_ticket_number")
  ticketDocumentNumber String?      @map("ticket_document_number")
  couponNumber         String?      @map("coupon_number")
  airlineCode          String?      @map("airline_code")
  pnrReference         String?      @map("pnr_reference")
  providerTicketId     String?      @map("provider_ticket_id")
  ticketStatus         TicketStatus @default(PENDING) @map("ticket_status")
  issuedAt             DateTime?    @map("issued_at")
  rawTicketPayload     Json?        @map("raw_ticket_payload")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  booking   MasterBooking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  passenger BookingPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  journey   BookingJourney?  @relation(fields: [journeyId], references: [id])
  segment   BookingSegment?  @relation(fields: [segmentId], references: [id])
  pnr       BookingPnr?      @relation(fields: [pnrId], references: [id])
  coupons   TicketCoupon[]

  @@index([bookingId])
  @@index([passengerId])
  @@index([ticketNumber])
  @@index([eTicketNumber])
  @@map("booking_tickets")
}

// ── Ticket Coupons (one coupon per segment per ticket) ──

model TicketCoupon {
  id                 String       @id @default(cuid())
  ticketId           String       @map("ticket_id")
  passengerId        String       @map("passenger_id")
  segmentId          String       @map("segment_id")
  couponNumber       String?      @map("coupon_number")
  couponStatus       CouponStatus @default(OPEN) @map("coupon_status")
  flightNumber       String?      @map("flight_number")
  airlineCode        String?      @map("airline_code")
  originAirport      String?      @map("origin_airport")
  destinationAirport String?      @map("destination_airport")
  departureDateTime  DateTime?    @map("departure_datetime")
  arrivalDateTime    DateTime?    @map("arrival_datetime")
  fareClass          String?      @map("fare_class")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  ticket    BookingTicket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  passenger BookingPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  segment   BookingSegment   @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([passengerId])
  @@index([segmentId])
  @@map("ticket_coupons")
}

// ── Seats ─────────────────────────────────────

model BookingSeat {
  id              String     @id @default(cuid())
  bookingId       String     @map("booking_id")
  passengerId     String     @map("passenger_id")
  journeyId       String     @map("journey_id")
  segmentId       String     @map("segment_id")
  seatNumber      String     @map("seat_number")
  seatType        String     @default("unknown") @map("seat_type")
  seatPrice       Decimal    @default(0) @map("seat_price") @db.Decimal(10, 2)
  currency        String     @default("USD")
  providerSeatId  String?    @map("provider_seat_id")
  seatStatus      SeatStatus @default(SELECTED) @map("seat_status")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  booking   MasterBooking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  passenger BookingPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  journey   BookingJourney   @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  segment   BookingSegment   @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([passengerId])
  @@map("booking_seats")
}

// ── Meals ─────────────────────────────────────

model BookingMeal {
  id          String     @id @default(cuid())
  bookingId   String     @map("booking_id")
  passengerId String     @map("passenger_id")
  journeyId   String     @map("journey_id")
  segmentId   String?    @map("segment_id")
  direction   JourneyDir @map("direction")
  mealCode    String     @map("meal_code")
  mealLabel   String     @map("meal_label")
  mealPrice   Decimal    @default(0) @map("meal_price") @db.Decimal(10, 2)
  currency    String     @default("USD")
  mealStatus  MealStatus @default(REQUESTED) @map("meal_status")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  booking   MasterBooking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  passenger BookingPassenger @relation(fields: [passengerId], references: [id], onDelete: Cascade)
  journey   BookingJourney   @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  segment   BookingSegment?  @relation(fields: [segmentId], references: [id])

  @@index([bookingId])
  @@index([passengerId])
  @@map("booking_meals")
}

// ── Baggage ───────────────────────────────────

model BookingBaggage {
  id          String   @id @default(cuid())
  bookingId   String   @map("booking_id")
  passengerId String?  @map("passenger_id")
  journeyId   String?  @map("journey_id")
  segmentId   String?  @map("segment_id")
  baggageType String   @default("checked") @map("baggage_type")
  quantity    Int      @default(1)
  weightValue Decimal? @map("weight_value") @db.Decimal(6, 2)
  weightUnit  String?  @map("weight_unit")
  baggagePrice Decimal @default(0) @map("baggage_price") @db.Decimal(10, 2)
  currency    String   @default("USD")
  status      String   @default("confirmed")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  booking   MasterBooking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  passenger BookingPassenger? @relation(fields: [passengerId], references: [id])
  journey   BookingJourney?   @relation(fields: [journeyId], references: [id])

  @@index([bookingId])
  @@map("booking_baggage")
}

// ── Provider Ancillaries (baggage/seat/meal from provider APIs) ──

model BookingAncillary {
  id                String   @id @default(cuid())
  bookingId         String   @map("booking_id")
  provider          String   // DUFFEL, MYSTIFLY
  providerOfferId   String   @map("provider_offer_id")
  providerServiceId String   @map("provider_service_id")
  ancillaryType     String   @map("ancillary_type") // CHECKED_BAG, EXTRA_CHECKED_BAG, CARRY_ON, SEAT, MEAL, LOUNGE_ACCESS, PRIORITY_BOARDING
  passengerId       String?  @map("passenger_id")
  segmentId         String?  @map("segment_id")
  journeyId         String?  @map("journey_id")
  airportCode       String?  @map("airport_code")
  label             String
  included          Boolean  @default(false)
  amount            Decimal  @default(0) @db.Decimal(10, 2)
  currency          String   @default("USD")
  quantity          Int      @default(1)
  rawProviderData   Json?    @map("raw_provider_data")
  createdAt         DateTime @default(now()) @map("created_at")

  booking MasterBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_ancillaries")
}

// ── Add-ons (insurance, price protection, etc.) ──

model BookingAddon {
  id          String   @id @default(cuid())
  bookingId   String   @map("booking_id")
  passengerId String?  @map("passenger_id")
  journeyId   String?  @map("journey_id")
  segmentId   String?  @map("segment_id")
  addonType   String   @map("addon_type")
  addonName   String   @map("addon_name")
  description String?
  amount      Decimal  @default(0) @db.Decimal(10, 2)
  currency    String   @default("USD")
  status      String   @default("confirmed")
  metadataJson Json?   @map("metadata_json")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  booking   MasterBooking     @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  passenger BookingPassenger? @relation(fields: [passengerId], references: [id])
  journey   BookingJourney?   @relation(fields: [journeyId], references: [id])

  @@index([bookingId])
  @@map("booking_addons")
}

// ── Payments ──────────────────────────────────

model BookingPayment {
  id                   String        @id @default(cuid())
  bookingId            String        @map("booking_id")
  stripePaymentIntentId String?      @map("stripe_payment_intent_id")
  amount               Decimal       @db.Decimal(10, 2)
  currency             String        @default("USD")
  paymentMethodType    String?       @map("payment_method_type")
  cardLast4            String?       @map("card_last4")
  status               MbPaymentTxStatus @default(PENDING) @map("status")
  paidAt               DateTime?     @map("paid_at")
  rawPaymentPayload    Json?         @map("raw_payment_payload")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  booking MasterBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([stripePaymentIntentId])
  @@map("booking_payments")
}

// ── Timeline Events ───────────────────────────

model BookingEvent {
  id               String   @id @default(cuid())
  bookingId        String   @map("booking_id")
  eventType        String   @map("event_type")
  eventTitle       String   @map("event_title")
  eventDescription String?  @map("event_description") @db.Text
  actorType        String   @default("system") @map("actor_type")
  actorId          String?  @map("actor_id")
  actorName        String?  @map("actor_name")
  payloadJson      Json?    @map("payload_json")
  createdAt        DateTime @default(now()) @map("created_at")

  booking MasterBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([bookingId, createdAt])
  @@map("booking_events")
}

// ── Admin Notes ───────────────────────────────

model BookingNote {
  id          String    @id @default(cuid())
  bookingId   String    @map("booking_id")
  noteText    String    @map("note_text") @db.Text
  isInternal  Boolean   @default(true) @map("is_internal")
  createdById String?   @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  booking   MasterBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  createdBy AdminUser?    @relation(fields: [createdById], references: [id])

  @@index([bookingId])
  @@map("booking_notes")
}

// ── Raw Provider Payloads ─────────────────────

model BookingProviderPayload {
  id                String   @id @default(cuid())
  bookingId         String   @map("booking_id")
  provider          String
  payloadType       String   @map("payload_type")
  providerReference String?  @map("provider_reference")
  payloadJson       Json     @map("payload_json")
  createdAt         DateTime @default(now()) @map("created_at")

  booking MasterBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_provider_payloads")
}

// ═══════════════════════════════════════════════
// ADMIN AUTH
// ═══════════════════════════════════════════════

model AdminUser {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String?   @map("password_hash")
  fullName           String    @map("full_name")
  phone              String?
  role               AdminRole @default(SUPPORT)
  isActive           Boolean   @default(true) @map("is_active")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  lastLoginAt        DateTime? @map("last_login_at")
  lastLoginIp        String?   @map("last_login_ip")
  createdById        String?   @map("created_by_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  otps         AdminOtp[]
  sessions     AdminSession[]
  auditLogs    AuditLog[]
  bookingNotes BookingNote[]
  supportTickets SupportTicket[]
  supportMessages SupportTicketMessage[]
  failedBookings BookingFailureAudit[]

  // Commercial fee management relations
  createdPlatformFees        PlatformFeeRule[]        @relation("PlatformFeeCreatedBy")
  updatedPlatformFees        PlatformFeeRule[]        @relation("PlatformFeeUpdatedBy")
  createdProtectionProducts  ProtectionProductRule[]   @relation("ProtectionProductCreatedBy")
  updatedProtectionProducts  ProtectionProductRule[]   @relation("ProtectionProductUpdatedBy")
  createdInsuranceProducts   TravelInsuranceRule[]     @relation("InsuranceProductCreatedBy")
  updatedInsuranceProducts   TravelInsuranceRule[]     @relation("InsuranceProductUpdatedBy")

  @@index([email])
  @@map("admin_users")
}

model AdminOtp {
  id          String    @id @default(cuid())
  adminUserId String    @map("admin_user_id")
  otpHash     String    @map("otp_hash")
  expiresAt   DateTime  @map("expires_at")
  attempts    Int       @default(0)
  used        Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
  @@map("admin_otps")
}

model AdminSession {
  id             String   @id @default(cuid())
  adminUserId    String   @map("admin_user_id")
  token          String   @unique
  refreshToken   String?  @unique @map("refresh_token")
  expiresAt      DateTime @map("expires_at")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  ipAddress      String?  @map("ip_address")
  userAgent      String?  @map("user_agent")
  createdAt      DateTime @default(now()) @map("created_at")

  adminUser AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([token])
  @@map("admin_sessions")
}

// ═══════════════════════════════════════════════
// SUPPORT SYSTEM
// ═══════════════════════════════════════════════

model SupportTicket {
  id              String    @id @default(cuid())
  ticketNumber    String?   @unique @map("ticket_number")  // e.g. FM-TKT-0001 or FS-URG-10001
  sequenceNumber  Int?      @unique @map("sequence_number") @default(autoincrement())
  subject         String
  description     String    @db.Text
  priority        String    // LOW, MEDIUM, HIGH, URGENT
  status          String    // OPEN, IN_PROGRESS, WAITING_CUSTOMER, ESCALATED, RESOLVED, CLOSED
  category        String
  channel         String    @default("WEB")  // WEB, WHATSAPP
  urgency         String?   // NORMAL, URGENT
  customerName    String    @map("customer_name")
  customerEmail   String    @map("customer_email")
  customerPhone   String?   @map("customer_phone")
  bookingRef      String?   @map("booking_ref")
  airlinePnr      String?   @map("airline_pnr")
  assignedToId    String?   @map("assigned_to_id")
  failureAuditId  String?   @unique @map("failure_audit_id")
  whatsappNumberUsed  String?  @map("whatsapp_number_used")
  whatsappMessageText String? @db.Text @map("whatsapp_message_text")
  whatsappOpenedAt    DateTime? @map("whatsapp_opened_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  assignedTo      AdminUser?             @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  failureAudit    BookingFailureAudit?   @relation(fields: [failureAuditId], references: [id], onDelete: SetNull)
  messages        SupportTicketMessage[]

  // ── Cancellation workflow linkage ───────────────────────
  ticketType        String?   @map("ticket_type")      // BOOKING_CANCELLATION, GENERAL, BOOKING_CHANGE, etc.
  cancellationId    String?   @map("cancellation_id")  // Link to CancellationRecord
  bookingRefundId   String?   @map("booking_refund_id") // Link to BookingRefund
  queue             String?   @map("queue")            // CANCELLATION_SUPPORT, REFUND_RECONCILIATION_QUEUE
  providerPnr       String?   @map("provider_pnr")
  providerBookingRef String?  @map("provider_booking_ref")
  correlationId     String?   @map("correlation_id")
  escalatedAt       DateTime? @map("escalated_at")
