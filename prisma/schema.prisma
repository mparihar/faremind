// ═══════════════════════════════════════════════
// BOOKING FAILURE AUDITS
// ═══════════════════════════════════════════════

model BookingFailureAudit {
  id                    String    @id @default(cuid())

  // Customer identification
  customerEmail         String    @map("customer_email")
  customerName          String    @map("customer_name")
  customerPhone         String?   @map("customer_phone")
  userId                String?   @map("user_id")

  // Route & flight details
  originAirport         String    @map("origin_airport")
  destinationAirport    String    @map("destination_airport")
  routeLabel            String    @map("route_label")
  tripType              String    @default("ONE_WAY") @map("trip_type")
  departureDate         String?   @map("departure_date")
  returnDate            String?   @map("return_date")
  airline               String?
  cabinClass            String?   @map("cabin_class")

  // Passenger details
  passengerCount        Int       @map("passenger_count")
  passengersJson        String    @map("passengers_json") @db.Text

  // Pricing & fare
  totalAmount           Decimal   @map("total_amount") @db.Decimal(10, 2)
  currency              String    @default("USD")
  offerId               String?   @map("offer_id")
  fareName              String?   @map("fare_name")

  // Error details (root cause — internal only, never shown to customer)
  errorCode             String    @map("error_code")
  errorMessage          String    @map("error_message") @db.Text
  customerMessage       String    @map("customer_message")
  failureStage          String    @map("failure_stage")

  // Payment context
  stripePaymentIntentId String?   @map("stripe_payment_intent_id")
  sessionId             String?   @map("session_id")

  // Admin resolution tracking
  status                String    @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  assignedToId          String?   @map("assigned_to_id")
  assignedTo            AdminUser? @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  resolvedAt            DateTime? @map("resolved_at")
  resolvedBy            String?   @map("resolved_by")
  resolutionNotes       String?   @map("resolution_notes") @db.Text

  createdAt             DateTime  @default(now()) @map("created_at")

  // Offer lifecycle timestamps (from Duffel)
  offerProvidedAt       DateTime? @map("offer_provided_at")
  offerExpiresAt        DateTime? @map("offer_expires_at")

  // Linked support ticket (auto-created when failure is logged)
  supportTicket         SupportTicket?

  @@index([customerEmail])
  @@index([createdAt])
  @@index([errorCode])
  @@index([resolvedAt])
  @@map("booking_failure_audits")
}

