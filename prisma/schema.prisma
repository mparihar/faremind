  FIRST
}

enum TripTypeScopeEnum {
  ALL
  ONE_WAY
  ROUND_TRIP
  MULTI_CITY
}

enum RouteScopeTypeEnum {
  ALL
  DOMESTIC
  INTERNATIONAL
  CUSTOM
}

enum ProtectionPricingModel {
  FIXED_PER_TRAVELER
  FIXED_PER_BOOKING
  PERCENTAGE_OF_FARE
  PROVIDER_QUOTED
}

enum InsurancePricingModel {
  FIXED_PER_TRAVELER
  FIXED_PER_BOOKING
  PERCENTAGE_OF_BOOKING_TOTAL
  PROVIDER_QUOTED
}

enum ChargeType {
  SERVICE_FEE
  MARKUP_FEE
  PRICE_DROP_PROTECTION
  TRAVEL_INSURANCE
}

enum ChargeSourceType {
  PLATFORM
  PROVIDER
  ADMIN_CONFIG
}

// ── Platform Fee Rules ────────────────────────────

model PlatformFeeRule {
  id                String             @id @default(cuid())
  feeType           FeeType            @map("fee_type")
  feeName           String             @map("fee_name")
  feeDescription    String?            @map("fee_description")
  calculationModel  CalculationModel   @map("calculation_model")
  fixedAmount       Decimal?           @map("fixed_amount") @db.Decimal(10, 2)
  percentageValue   Decimal?           @map("percentage_value") @db.Decimal(6, 4)
  currency          String             @default("USD")
  appliesToAdult    Boolean            @default(true) @map("applies_to_adult")
  appliesToChild    Boolean            @default(true) @map("applies_to_child")
  appliesToInfant   Boolean            @default(true) @map("applies_to_infant")
  providerScope     ProviderScopeEnum  @default(ALL) @map("provider_scope")
  cabinScope        CabinScopeEnum     @default(ALL) @map("cabin_scope")
  tripTypeScope     TripTypeScopeEnum  @default(ALL) @map("trip_type_scope")
  routeScopeType    RouteScopeTypeEnum @default(ALL) @map("route_scope_type")
  originCountry     String?            @map("origin_country")
  destinationCountry String?           @map("destination_country")
  active            Boolean            @default(true)
  effectiveFrom     DateTime           @default(now()) @map("effective_from")
  effectiveTo       DateTime?          @map("effective_to")
  priority          Int                @default(1)

  // Audit
  createdByAdminId    String?          @map("created_by_admin_id")
  createdByAdminEmail String?          @map("created_by_admin_email")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedByAdminId    String?          @map("updated_by_admin_id")
  updatedByAdminEmail String?          @map("updated_by_admin_email")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  // Soft delete
  deletedAt         DateTime?          @map("deleted_at")
  deletedBy         String?            @map("deleted_by")

  // Relations
  createdByAdmin    AdminUser?         @relation("PlatformFeeCreatedBy", fields: [createdByAdminId], references: [id], onDelete: SetNull)
  updatedByAdmin    AdminUser?         @relation("PlatformFeeUpdatedBy", fields: [updatedByAdminId], references: [id], onDelete: SetNull)

  @@index([feeType, active])
  @@index([providerScope])
  @@index([cabinScope])
  @@index([priority])
  @@map("platform_fee_rules")
}

