  quoteExpiresAt        DateTime? @map("quote_expires_at")
  providerRequestId     String?  @map("provider_request_id")
  providerQuoteResponse Json?    @map("provider_quote_response")
  providerExecResponse  Json?    @map("provider_exec_response")
  providerStatus        String?  @map("provider_status")
