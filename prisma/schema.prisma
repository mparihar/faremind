// ── Fare Tier Templates (replaces hardcoded FARE_TEMPLATES) ───

model FareTierTemplate {
  id                  String   @id @default(cuid())
  name                String                                    // "Economy Basic", "Economy Standard", etc.
  cabin               String                                    // "economy", "premium_economy", "business", "first"
  priceMultiplier     Decimal  @map("price_multiplier") @db.Decimal(6, 4)
  displayOrder        Int      @default(0)  @map("display_order")

  // Baggage
  carryOn             Boolean  @default(true)  @map("carry_on")
  carryOnPieces       Int      @default(1)     @map("carry_on_pieces")
  carryOnWeightKg     Decimal? @map("carry_on_weight_kg") @db.Decimal(5, 1)
  checkedBags         Int      @default(0)     @map("checked_bags")
  checkedWeightKg     Decimal? @map("checked_weight_kg") @db.Decimal(5, 1)
  extraBagFeeUsd      Decimal? @map("extra_bag_fee_usd") @db.Decimal(10, 2)

  // Policies
  refundable          Boolean  @default(false)
  refundFeeUsd        Decimal? @map("refund_fee_usd") @db.Decimal(10, 2)
  changeable          Boolean  @default(false)
  changeFeeUsd        Decimal? @map("change_fee_usd") @db.Decimal(10, 2)
  seatSelection       String   @default("fee") @map("seat_selection")          // "free" | "fee" | "not_available"
  seatSelectionFeeUsd Decimal? @map("seat_selection_fee_usd") @db.Decimal(10, 2)
  upgradeable         Boolean  @default(false)
  loungeAccess        Boolean  @default(false) @map("lounge_access")
  priorityBoarding    Boolean  @default(false) @map("priority_boarding")
  milesEarning        String   @default("reduced") @map("miles_earning")       // "full" | "reduced" | "none"

  active              Boolean  @default(true)
  updatedBy           String?  @map("updated_by")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([cabin, active])
  @@index([displayOrder])
  @@map("fare_tier_templates")
}

